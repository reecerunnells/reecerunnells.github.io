<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if title %}{{ title }} · {{ site.name }}{% else %}{{ site.title }}{% endif %}</title>
  {% if description %}
  <meta name="description" content="{{ description }}">
  {% else %}
  <meta name="description" content="{{ site.description }}">
  {% endif %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Semi+Condensed:ital,wght@0,500;0,600;0,700;0,800;1,500&family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,500;1,600&display=swap" rel="stylesheet">
  <link rel="icon" href="{{ '/assets/favicon.svg' | url }}" type="image/svg+xml">
  <link rel="stylesheet" href="{{ '/css/main.css' | url }}">
{%- if previewAuthHash %}
  <script>
  (function () {
    var H = "{{ previewAuthHash }}";
    var k = "reece-dev-preview";
    try {
      if (H && sessionStorage.getItem(k) === H) {
        document.documentElement.classList.add("dev-preview-unlocked");
      }
    } catch (e) { /* noop */ }
  })();
  </script>
  <style>
  html:not(.dev-preview-unlocked) .masthead,
  html:not(.dev-preview-unlocked) .skip-link,
  html:not(.dev-preview-unlocked) .sheet,
  html:not(.dev-preview-unlocked) .colophon { visibility: hidden; }
  </style>
{%- endif %}
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>
  <header class="masthead" role="banner">
    <div class="masthead__top">
      <span class="masthead__rule masthead__rule--left" aria-hidden="true"></span>
      <p class="masthead__kicker">
        <span>{{ site.mastheadDate }}</span>
        <span class="masthead__tag">{{ site.mastheadTag }}</span>
        <span>{{ site.mastheadIssue }}</span>
      </p>
      <span class="masthead__rule masthead__rule--right" aria-hidden="true"></span>
    </div>
    <div class="masthead__brand">
      <a class="masthead__logotype" href="{{ '/' | url }}">{{ site.name }}</a>
    </div>
    <nav class="masthead__toc" aria-label="Primary">
      <ol class="toc-grid">
        {%- for item in navigation.items %}
        <li class="toc-grid__cell">
          <a class="toc-grid__link" href="{{ item.url | url }}"{% if page.url == (item.url | url) %} aria-current="page"{% endif %}>
            <span class="toc-grid__num" aria-hidden="true">{{ item.num }}</span>
            <span class="toc-grid__slug">{{ item.slug }}</span>
            <span class="toc-grid__label">{{ item.label }}</span>
          </a>
        </li>
        {%- endfor %}
      </ol>
    </nav>
  </header>
  <main id="main" class="sheet">
    {{ content | safe }}
  </main>
  <footer class="colophon">
    <div class="colophon__inner">
      <p class="colophon__line">© {% year %} {{ site.author }}</p>
      <p class="colophon__credit">Set in <span class="colophon__serif">Cormorant Garamond</span> &amp; <span class="colophon__sans">Barlow Semi Condensed</span> · Built with <a href="https://www.11ty.dev/">Eleventy</a></p>
    </div>
  </footer>
{%- if previewAuthHash %}
  <noscript><div class="preview-gate-noscript" role="alert">This preview requires JavaScript to unlock.</div></noscript>
  <style>
    .preview-gate-noscript{position:fixed;inset:0;display:flex;align-items:center;justify-content:center;background:#000;color:#f4a442;padding:1.5rem;font-family:system-ui,sans-serif;font-weight:700;text-align:center;z-index:2147483646}
    .preview-gate{position:fixed;inset:0;z-index:2147483647;display:flex;align-items:center;justify-content:center;padding:1.25rem;background:rgba(0,0,0,.88);font-family:Barlow Semi Condensed,system-ui,sans-serif}
    .preview-gate__box{width:100%;max-width:22rem;background:#f7f5f0;color:#121212;padding:1.5rem;border:1px solid #000;box-shadow:8px 8px 0 #f4a442}
    .preview-gate__box h2{margin:0 0 .5rem;font-size:.85rem;letter-spacing:.12em;text-transform:uppercase}
    .preview-gate__box p{margin:0 0 1rem;font-size:.95rem;line-height:1.4;color:#4a4844}
    .preview-gate__field{width:100%;padding:.55rem .65rem;font-size:1rem;border:1px solid #000;margin-bottom:.65rem;box-sizing:border-box}
    .preview-gate__btn{width:100%;padding:.65rem;font-size:.85rem;font-weight:800;letter-spacing:.08em;text-transform:uppercase;background:#000;color:#fff;border:none;cursor:pointer}
    .preview-gate__btn:hover,.preview-gate__btn:focus-visible{background:#f4a442;color:#000}
    .preview-gate__err{min-height:1.25rem;margin:.5rem 0 0;font-size:.85rem;color:#a32020;font-weight:600}
    .preview-gate__hint{margin-top:.85rem;font-size:.75rem;color:#4a4844;line-height:1.35}
  </style>
  <script>
(function () {
  var H = "{{ previewAuthHash }}";
  if (!H || !window.crypto || !window.crypto.subtle) return;
  var k = "reece-dev-preview";
  try {
    if (sessionStorage.getItem(k) === H) {
      document.documentElement.classList.add("dev-preview-unlocked");
      return;
    }
  } catch (e) { /* private mode */ }

  function hex(buf) {
    return Array.prototype.map.call(new Uint8Array(buf), function (b) {
      return ("0" + b.toString(16)).slice(-2);
    }).join("");
  }

  var gate = document.createElement("div");
  gate.className = "preview-gate";
  gate.setAttribute("role", "dialog");
  gate.setAttribute("aria-modal", "true");
  gate.setAttribute("aria-labelledby", "preview-gate-title");
  gate.innerHTML =
    '<div class="preview-gate__box">' +
    '<h2 id="preview-gate-title">Preview</h2>' +
    '<p>This build is for review. Enter the preview password from the maintainer.</p>' +
    '<form id="preview-gate-form">' +
    '<label class="visually-hidden" for="preview-gate-pw">Password</label>' +
    '<input class="preview-gate__field" id="preview-gate-pw" name="password" type="password" autocomplete="current-password" required placeholder="Password" />' +
    '<button type="submit" class="preview-gate__btn">Unlock</button>' +
    '<p class="preview-gate__err" id="preview-gate-err" aria-live="polite"></p>' +
    '</form>' +
    '<p class="preview-gate__hint">This is not server-side HTTP auth; anyone can inspect this page. Use a long random secret and treat the preview as public.</p>' +
    "</div>";
  document.body.appendChild(gate);

  var form = gate.querySelector("#preview-gate-form");
  var input = gate.querySelector("#preview-gate-pw");
  var err = gate.querySelector("#preview-gate-err");
  input.focus();

  form.addEventListener("submit", function (ev) {
    ev.preventDefault();
    err.textContent = "";
    var raw = input.value;
    if (!raw) return;
    crypto.subtle.digest("SHA-256", new TextEncoder().encode(raw)).then(function (buf) {
      if (hex(buf) === H) {
        try { sessionStorage.setItem(k, H); } catch (e2) {}
        document.documentElement.classList.add("dev-preview-unlocked");
        gate.remove();
      } else {
        err.textContent = "Wrong password.";
        input.value = "";
        input.focus();
      }
    });
  });
})();
  </script>
{%- endif %}
</body>
</html>
